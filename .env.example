# Fichier d'environnement pour OpenCode Docker avec GitHub Copilot
# Copiez ce fichier vers .env et remplissez les valeurs

# Token GitHub pour authentification OpenCode/Copilot (REQUIS)
# Obtenir un token: https://github.com/settings/tokens
# Permissions requises: copilot, repo (pour PR reviews)
GITHUB_TOKEN=your_github_token_here

# Modèle OpenCode à utiliser (OPTIONNEL)
# Options disponibles:
#   - github-copilot/claude-sonnet-4.5 (défaut, équilibré)
#   - github-copilot/claude-opus-4.7 (plus puissant)
#   - github-copilot/gpt-5.5 (dernière version GPT)
#   - github-copilot/gemini-3.1-pro-preview
OPENCODE_MODEL=github-copilot/claude-sonnet-4.5

# Niveau de log (DEBUG, INFO, WARN, ERROR)
OPENCODE_LOG_LEVEL=INFO

# Numéro de PR pour les revues (utilisé par review-pr)
PR_NUMBER=

# Publier automatiquement les revues sur GitHub (true/false)
POST_TO_GITHUB=false

# Type de documentation à générer
DOC_TYPE=all

# Règles de refactoring
REFACTOR_RULES=standard

# Type d'analyse
ANALYSIS_TYPE=full

# === Token Optimization Skills (OPTIONNEL) ===
# Ces skills sont activés par défaut pour économiser 85-95% de tokens

# Activer/désactiver RTK (Rust Token Killer - optimisation CLI)
# Réduit les sorties de commandes de 60-90%
RTK_ENABLED=true

# Mode Caveman pour compression de langage
# Options: lite (~40%), full (~65%), ultra (~75%+), wenyan (~80%+)
CAVEMAN_MODE=ultra

# Activation automatique de Caveman
CAVEMAN_AUTO=true

# Alternative: Fournir directement le fichier auth.json complet (format JSON)
# OPENCODE_AUTH_JSON='{"github-copilot":{"type":"oauth","token":"..."}}'
